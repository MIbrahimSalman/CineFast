<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Movie Poster -->
        <ImageView
            android:id="@+id/imgMoviePoster"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:scaleType="centerCrop"
            android:src="@drawable/dark_knight"
            android:background="@drawable/bg_rounded_card"
            android:clipToOutline="true" />

        <!-- Movie Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/textMovieName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Movie Title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textMovieGenre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Genre • Duration"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btnTrailer"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginEnd="8dp"
                    android:text="▶ Trailer"
                    android:textColor="#00C853"
                    android:textSize="11sp"
                    android:background="@drawable/bg_tag_outline"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btnBookSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Book Seats"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:background="@drawable/bg_tag_green"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
