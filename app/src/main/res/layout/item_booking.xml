<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_movie_item">

    <!-- The Grey Poster Placeholder -->
    <View
        android:id="@+id/imgPoster"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="10dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_poster_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Movie Title -->
    <TextView
        android:id="@+id/textMovieTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/imgPoster"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Cancel Button (Red X) -->
    <ImageButton
        android:id="@+id/btnCancelBooking"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_delete"
        app:tint="#FF0000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Clock Icon & Date -->
    <ImageView
        android:id="@+id/iconClock"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="12dp"
        android:src="@android:drawable/ic_menu_recent_history"
        app:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="@id/textMovieTitle"
        app:layout_constraintTop_toBottomOf="@id/textMovieTitle" />

    <TextView
        android:id="@+id/textDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/iconClock"
        app:layout_constraintStart_toEndOf="@id/iconClock"
        app:layout_constraintTop_toTopOf="@id/iconClock" />

    <!-- Ticket Icon & Count -->
    <ImageView
        android:id="@+id/iconTicket"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="8dp"
        android:src="@android:drawable/ic_menu_agenda"
        app:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="@id/textMovieTitle"
        app:layout_constraintTop_toBottomOf="@id/iconClock" />

    <TextView
        android:id="@+id/textSeats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/iconTicket"
        app:layout_constraintStart_toEndOf="@id/iconTicket"
        app:layout_constraintTop_toTopOf="@id/iconTicket" />

</androidx.constraintlayout.widget.ConstraintLayout>
