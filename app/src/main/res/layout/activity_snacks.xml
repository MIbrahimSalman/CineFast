<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".SnacksActivity">

    <TextView
        android:id="@+id/textLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Cine"
        android:textColor="#E50914"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FAST"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/textLogo"
        app:layout_constraintStart_toEndOf="@id/textLogo"
        app:layout_constraintTop_toTopOf="@id/textLogo" />

    <TextView
        android:id="@+id/textSelectItems"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Select Items"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textLogo" />

    <TextView
        android:id="@+id/textPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:text="Snacks &amp; Drinks"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSelectItems" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnConfirm"
        app:layout_constraintTop_toBottomOf="@id/textPageTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgPopcorn"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/popcorn"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/titlePopcorn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Popcorn"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgPopcorn"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Large / Buttered"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:layout_constraintStart_toEndOf="@id/imgPopcorn"
                    app:layout_constraintTop_toBottomOf="@id/titlePopcorn" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="$8.99"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgPopcorn"
                    app:layout_constraintTop_toBottomOf="@id/titlePopcorn"
                    android:layout_marginTop="24dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnMinusPopcorn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="-"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/qtyPopcorn"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPlusPopcorn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgNachos"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/nachos"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/titleNachos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Nachos"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgNachos"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="With Cheese Dip"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:layout_constraintStart_toEndOf="@id/imgNachos"
                    app:layout_constraintTop_toBottomOf="@id/titleNachos" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="$7.99"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgNachos"
                    app:layout_constraintTop_toBottomOf="@id/titleNachos"
                    android:layout_marginTop="24dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnMinusNachos"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="-"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/qtyNachos"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPlusNachos"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgDrink"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/soft_drink"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/titleDrink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Soft Drink"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgDrink"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Large / Any Flavor"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:layout_constraintStart_toEndOf="@id/imgDrink"
                    app:layout_constraintTop_toBottomOf="@id/titleDrink" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="$5.99"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgDrink"
                    app:layout_constraintTop_toBottomOf="@id/titleDrink"
                    android:layout_marginTop="24dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnMinusDrink"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="-"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/qtyDrink"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPlusDrink"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgCandy"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/candy"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/titleCandy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Candy Mix"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgCandy"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Assorted Candies"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    app:layout_constraintStart_toEndOf="@id/imgCandy"
                    app:layout_constraintTop_toBottomOf="@id/titleCandy" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="$6.99"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/imgCandy"
                    app:layout_constraintTop_toBottomOf="@id/titleCandy"
                    android:layout_marginTop="24dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnMinusCandy"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="-"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/qtyCandy"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPlusCandy"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_quantity_btn"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:padding="0dp"
                        android:gravity="center"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_confirm_btn"
        android:text="Confirm"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingVertical="14dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
