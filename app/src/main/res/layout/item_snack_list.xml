<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1A1A1A"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="6dp"
    android:gravity="center_vertical">

    <!-- Food Image -->
    <ImageView
        android:id="@+id/imgSnack"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_rounded_card"
        android:clipToOutline="true"
        android:contentDescription="Snack image" />

    <!-- Name + Price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/textSnackName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Popcorn"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSnackPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$8.99"
            android:textColor="#00C853"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Minus button -->
    <Button
        android:id="@+id/btnMinus"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="–"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="@drawable/bg_quantity_btn"
        android:padding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <!-- Quantity -->
    <TextView
        android:id="@+id/textQty"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Plus button -->
    <Button
        android:id="@+id/btnPlus"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="+"
        android:textColor="#000000"
        android:textSize="16sp"
        android:background="@drawable/bg_tag_green"
        android:padding="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
